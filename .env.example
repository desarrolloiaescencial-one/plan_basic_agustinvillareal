# ============================================================
# PRODE ONE — Variables de Entorno
# Copiar este archivo como .env y completar los valores reales
# ============================================================

# --- Google Apps Script Web App ---
# Pasos para obtener la URL:
#   1. Abrí tu Google Sheet → Extensiones → Apps Script
#   2. Pegá el contenido de Code.gs y guardá
#   3. Implementar → Nueva implementación → Tipo: Aplicación web
#   4. Ejecutar como: Yo mismo | Quién tiene acceso: Cualquier usuario
#   5. Copiá la URL generada aquí abajo
VITE_GAS_URL=https://script.google.com/macros/s/TU_ID_DE_DEPLOYMENT/exec

# --- API de Deportes (se configura en el propio Apps Script) ---
# La API Key deportiva NO va aquí — se guarda directamente en Apps Script
# usando el menú: 🏆 Prode One → 🔐 Configurar API Key
# Así la key nunca queda expuesta en el frontend.
